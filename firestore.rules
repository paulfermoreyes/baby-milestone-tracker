rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────

    // Returns true if the requesting user is authenticated
    function isAuthed() {
      return request.auth != null;
    }

    // Returns true if the requesting user owns the resource (legacy root collections)
    function ownsResource() {
      return isAuthed() && resource.data.userId == request.auth.uid;
    }

    // Returns true if the requesting user is a member of the given family document
    function isFamilyMember(familyId) {
      return isAuthed() &&
        request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
    }

    // ── User profile documents ───────────────────────────────────────────────
    match /users/{userId} {
      // Users can only read and write their own profile
      allow read, write: if isAuthed() && request.auth.uid == userId;

      // Birth Preparation Checklist (solo, cross-device)
      match /checklist/{checklistId} {
        allow read, write: if isAuthed() && request.auth.uid == userId;
      }
    }

    // ── Family documents ─────────────────────────────────────────────────────
    match /families/{familyId} {
      // Any authenticated user can create a family document (they become the first member)
      allow create: if isAuthed() && request.auth.uid in request.resource.data.members;

      // Any authenticated user can read or update family docs (needed for invite code lookups and linking)
      allow read, update: if isAuthed();

      // Nobody can delete a family document from the client
      allow delete: if false;

      // ── Shared tracker subcollections ──────────────────────────────────────

      // Kicks
      match /kicks/{kickId} {
        allow read, delete: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId) && request.resource.data.loggedBy == request.auth.uid;
        allow update: if false;
      }

      // Contractions
      match /contractions/{contractionId} {
        allow read, delete: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId) && request.resource.data.loggedBy == request.auth.uid;
        allow update: if false;
      }

      // Blood sugar
      match /bloodsugar/{bsId} {
        allow read, delete: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId) && request.resource.data.loggedBy == request.auth.uid;
        allow update: if false;
      }

      // Milk counter
      match /milk/{milkId} {
        allow read, delete: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId) && request.resource.data.loggedBy == request.auth.uid;
        allow update: if false;
      }

      // Symptoms
      match /symptoms/{symptomId} {
        allow read, delete: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId) && request.resource.data.loggedBy == request.auth.uid;
        allow update: if false;
      }

      // Weight
      match /weight/{weightId} {
        allow read, delete: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId) && request.resource.data.loggedBy == request.auth.uid;
        allow update: if false;
      }

      // Baptism Organizer
      match /baptism/{baptismId} {
        allow read, write: if isFamilyMember(familyId);
      }

      // Birth Preparation Checklist
      match /checklist/{checklistId} {
        allow read, write: if isFamilyMember(familyId);
      }
    }

    // ── Legacy root collections (personal, pre-link) ─────────────────────────
    // These remain for users who haven't linked with a partner yet.

    match /kicks/{kickId} {
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if ownsResource();
      allow update: if false;
    }

    match /milk/{milkId} {
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if ownsResource();
      allow update: if false;
    }

    match /bloodsugar/{bsId} {
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if ownsResource();
      allow update: if false;
    }

    match /contractions/{contractionId} {
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if ownsResource();
      allow update: if false;
    }

    match /symptoms/{symptomId} {
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if ownsResource();
      allow update: if false;
    }

    match /weight/{weightId} {
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if ownsResource();
      allow update: if false;
    }

    match /baptism/{baptismId} {
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthed() && (resource.data.userId == request.auth.uid || baptismId == request.auth.uid);
    }
  }
}
